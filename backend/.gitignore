# ============================================================
# Backend .gitignore
# ============================================================

# Maven
target/
*.class
target/*.jar
*.war

# Keep Maven Wrapper JAR – must be committed to source control
!.mvn/wrapper/maven-wrapper.jar

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/

# Environment variables – NEVER commit
.env

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
