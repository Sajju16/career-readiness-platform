# ============================================================
# Root Project .gitignore
# ============================================================

# Environment variables & Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Frontend
frontend/node_modules/
frontend/dist/
frontend/build/
.npm/

# Backend
backend/target/
backend/*.class
backend/*.jar
.mvn/wrapper/maven-wrapper.jar

# AI Service
ai-service/venv/
ai-service/.venv/
ai-service/__pycache__/
ai-service/*.py[cod]

# IDE & OS
.idea/
.vscode/
.DS_Store
Thumbs.db
